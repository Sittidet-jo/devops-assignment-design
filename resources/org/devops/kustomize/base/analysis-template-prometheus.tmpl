apiVersion: argoproj.io/v1alpha1
kind: AnalysisTemplate
metadata:
  name: {{APP_NAME}}-analysis-prometheus
spec:
  args:
    - name: namespace
      value: {{NAMESPACE}}
    - name: podRegex
      value: "{{APP_NAME}}-.*"
    - name: prom_interval
      value: "1m"

  metrics:
    - name: error-rate
      interval: 30s
      count: 3
      failureLimit: 1
      provider:
        prometheus:
          address: "{{PROM_URL}}"
          query: |
            sum(rate(http_requests_total{
              namespace="{{args.namespace}}",
              pod=~"{{args.podRegex}}",
              status=~"5.*"
            }[1m])) 
            / 
            sum(rate(http_requests_total{
              namespace="{{args.namespace}}",
              pod=~"{{args.podRegex}}"
            }[1m]))
      successCondition: len(result) == 0 || result[0] != result[0] || result[0] < 0.01

    - name: restarts
      interval: 30s
      count: 3
      failureLimit: 1
      provider:
        prometheus:
          address: "{{PROM_URL}}"
          query: |
            sum(increase(kube_pod_container_status_restarts_total{
              namespace="{{args.namespace}}",
              pod=~"{{args.podRegex}}"
            }[1m]))
      successCondition: len(result) == 0 || result[0] <= 1