apiVersion: autoscaling.k8s.io/v1
kind: VerticalPodAutoscaler
metadata:
  name: {{NAME}}
spec:
  targetRef:
    apiVersion: {{TARGET_API}}
    kind: {{TARGET_KIND}}
    name: {{TARGET_NAME}}
  updatePolicy:
    updateMode: "{{UPDATE_MODE}}"
  resourcePolicy:
    containerPolicies:
      - containerName: '*'
        minAllowed:
          cpu: 20m
          memory: 50Mi
        maxAllowed:
          cpu: 2000m
          memory: 4Gi
        controlledResources: ["cpu", "memory"]